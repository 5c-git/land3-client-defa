header.header
  div.header__top
    div.container
      div.header__top-wrapper
        div.header__logo
          img(src="./assets/images/logo.svg" width='143' height='60' alt="")

        a(href="#").header__search
          span Search
          svg(width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg")
            use(href='#icon-search')

        div.header__contacts
          a(href="tel:88005054580").header__link Sales Department 8 (800) 505-45-80
            
        button(type='button').header__burger
          span

      div.header__mobile-nav
        include ../mobile-nav/mobile-nav
            
  div.header__main
    div.container
      div.header__main-wrapper
        nav.header__nav
          a(href="#").header__link About us
          a(href="#").header__link News
          a(href="#").header__link Products
          a(href="#").header__link Blog
          a(href="#").header__link Contact

        div.header__actions
          div.button-magnetic
            a(href="#").button.button--transparent
              svg(width="18" height="19" viewBox="0 0 18 19" xmlns="http://www.w3.org/2000/svg")
                use(href='#icon-download')
              span Price List
          div.button-magnetic
            a(href="#").button
              svg(width="18" height="19" viewBox="0 0 18 19" xmlns="http://www.w3.org/2000/svg")
                use(href='#icon-cart-2')
              span Web Store